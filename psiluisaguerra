<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luisa Guerra | Psicóloga Clínica — Psicanálise, Saúde da Criança e Atendimento Humanizado</title>
    <meta name="description" content="Psicóloga clínica especialista em psicanálise, saúde da criança e psicologia hospitalar. Atendimento presencial em Salvador e online para todo Brasil.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-brown: #C4A57B;
            --light-brown: #E8DCC4;
            --soft-green: #A8C4A0;
            --dark-green: #7A9B74;
            --cream: #FAF7F0;
            --white: #FFFFFF;
            --text-dark: #2D3436;
            --text-medium: #636E72;
            --text-body: #74787C;
            --whatsapp: #25D366;
        }

        html {
            scroll-behavior: smooth;
            background-color: var(--cream);
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-body);
            line-height: 1.8;
            background-color: var(--cream);
            overflow-x: hidden;
        }

        /* LOADING SCREEN */
        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #FFFFFF;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 1;
            transition: opacity 0.8s ease;
        }

        #loading-screen.hide {
            opacity: 0;
            pointer-events: none;
        }

                                                                        .loading-profile-image {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            position: relative;
            margin-bottom: 2rem;
            animation: fadeIn 1s ease;
        }

        .loading-profile-image::before {
            display: none;
        }

        .loading-profile-image img {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            object-fit: cover;
            display: block;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
            border: 3px solid white;
        }

        .loading-profile-image::before {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            background: linear-gradient(45deg, var(--primary-brown), var(--soft-green), var(--primary-brown), var(--soft-green));
            background-size: 400% 400%;
            z-index: -1;
            animation: gradientRotate 6s linear infinite;
        }

        .loading-profile-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .loading-name {
            font-family: 'Quicksand', sans-serif;
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 0.5rem;
        }

        .loading-subtitle {
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: var(--soft-green);
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 3rem;
        }

        .loading-bar-container {
            width: 120px;
            height: 2px;
            background: rgba(196, 165, 123, 0.2);
            border-radius: 10px;
            overflow: hidden;
        }

        .loading-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-brown), var(--soft-green));
            width: 0%;
            animation: loadProgress 2.5s ease-in-out forwards;
        }

        @keyframes loadProgress {
            to { width: 100%; }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* HEADER */
        header {
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            background: rgba(250, 247, 240, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(196, 165, 123, 0.15);
            transition: all 0.3s ease;
        }

        header.scrolled {
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        }

        nav {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Quicksand', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--primary-brown);
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        nav a {
            text-decoration: none;
            color: var(--text-medium);
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.3s ease;
        }

        nav a:hover {
            color: var(--primary-brown);
        }

        .menu-toggle {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 5px;
        }

        .menu-toggle span {
            width: 30px;
            height: 3px;
            background: var(--soft-green);
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        /* HERO */
        #home {
            margin-top: 80px;
            min-height: 90vh;
            background: linear-gradient(135deg, var(--light-brown) 0%, var(--cream) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 2rem;
        }

        .hero-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

                                                                        .hero-profile-image {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            position: relative;
            margin-bottom: 2rem;
        }

        .hero-profile-image::before {
            display: none;
        }

        .hero-profile-image img {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            object-fit: cover;
            display: block;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            border: 3px solid white;
        }

        @keyframes spin {
            from {
                transform: rotate(0deg);
            }
            to {
                transform: rotate(360deg);
            }
        }

        .hero-profile-image::before {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            background: linear-gradient(45deg, var(--primary-brown), var(--soft-green), var(--primary-brown), var(--soft-green));
            background-size: 400% 400%;
            z-index: -1;
            animation: gradientRotate 6s linear infinite;
        }

        
            50% {
                background-position: 100% 50%;
            }
            100% {
                background-position: 0% 50%;
                transform: rotate(360deg);
            }
        }

        .hero-profile-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .hero-content h1 {
            font-family: 'Quicksand', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 0.5rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
            color: var(--soft-green);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 1.5rem;
        }

                .hero-quote {
            font-family: 'Inter', sans-serif;
            font-size: 1.4rem;
            font-style: italic;
            font-weight: 400;
            color: var(--text-medium);
            margin-bottom: 1.5rem;
            max-width: 700px;
        }

        .hero-description {
            font-size: 1rem;
            color: var(--text-body);
            margin-bottom: 2rem;
            max-width: 700px;
            line-height: 1.8;
        }

        .hero-crp {
            font-size: 0.9rem;
            color: var(--text-medium);
            margin-bottom: 2.5rem;
            font-weight: 500;
        }

        .hero-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary {
            padding: 1.1rem 2.5rem;
            text-decoration: none;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.3s ease;
            font-size: 1rem;
            display: inline-block;
        }

        .btn-primary {
            background: var(--soft-green);
            color: white;
            box-shadow: 0 4px 15px rgba(168, 196, 160, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 25px rgba(168, 196, 160, 0.4);
            background: var(--dark-green);
        }

        .btn-secondary {
            background: transparent;
            color: var(--primary-brown);
            border: 2px solid var(--primary-brown);
        }

        .btn-secondary:hover {
            background: var(--soft-green);
            color: white;
        }

        /* SECTIONS */
        section {
            position: relative;
            z-index: 1;
            padding: 6rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        h2 {
            font-family: 'Quicksand', sans-serif;
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 1rem;
            color: var(--text-dark);
            font-weight: 700;
        }

        .section-divider {
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-brown), var(--soft-green));
            margin: 1rem auto;
            border-radius: 10px;
        }

                .section-subtitle {
            text-align: center;
            color: var(--text-medium);
            font-size: 1.15rem;
            margin-bottom: 4rem;
            font-family: 'Inter', sans-serif;
            font-style: italic;
            font-weight: 400;
            opacity: 0.85;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }


        /* Elementos decorativos - bolinhas */
        .decorative-dots {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .dot {
            position: absolute;
            border-radius: 50%;
            opacity: 0.4;
        }

        .dot-1 {
            width: 7px;
            height: 7px;
            background: var(--soft-green);
            top: 15%;
            left: 10%;
            animation: float 6s ease-in-out infinite;
        }

        .dot-2 {
            width: 7px;
            height: 7px;
            background: var(--soft-green);
            top: 25%;
            right: 15%;
            animation: float 8s ease-in-out infinite 1s;
        }

        .dot-3 {
            width: 10px;
            height: 10px;
            background: var(--soft-green);
            top: 45%;
            left: 8%;
            animation: float 7s ease-in-out infinite 2s;
        }

        .dot-4 {
            width: 10px;
            height: 10px;
            background: var(--soft-green);
            top: 60%;
            right: 12%;
            animation: float 9s ease-in-out infinite 1.5s;
        }

        .dot-5 {
            width: 7px;
            height: 7px;
            background: var(--soft-green);
            top: 75%;
            left: 20%;
            animation: float 6.5s ease-in-out infinite 0.5s;
        }

        .dot-6 {
            width: 7px;
            height: 7px;
            background: var(--soft-green);
            top: 85%;
            right: 25%;
            animation: float 7.5s ease-in-out infinite 2.5s;
        }

        .dot-7 {
            width: 10px;
            height: 10px;
            background: var(--soft-green);
            top: 35%;
            left: 85%;
            animation: float 8.5s ease-in-out infinite 3s;
        }

        .dot-8 {
            width: 10px;
            height: 10px;
            background: var(--soft-green);
            top: 50%;
            left: 5%;
            animation: float 7s ease-in-out infinite 1s;
        }


        .dot-9 {
            width: 7px;
            height: 7px;
            background: var(--soft-green);
            top: 20%;
            left: 50%;
            animation: float 7.5s ease-in-out infinite 2s;
        }

        .dot-10 {
            width: 9px;
            height: 9px;
            background: var(--soft-green);
            top: 55%;
            right: 30%;
            animation: float 8.5s ease-in-out infinite 3.5s;
        }

        .dot-11 {
            width: 6px;
            height: 6px;
            background: var(--soft-green);
            top: 70%;
            left: 60%;
            animation: float 9s ease-in-out infinite 1.5s;
        }

        .dot-12 {
            width: 8px;
            height: 8px;
            background: var(--soft-green);
            top: 40%;
            right: 40%;
            animation: float 7s ease-in-out infinite 4s;
        }

        .dot-13 {
            width: 10px;
            height: 10px;
            background: var(--soft-green);
            top: 90%;
            left: 70%;
            animation: float 8s ease-in-out infinite 2.5s;
        }
        @keyframes float {
            0%, 100% {
                transform: translateY(0) translateX(0);
                opacity: 0.3;
            }
            50% {
                transform: translateY(-20px) translateX(10px);
                opacity: 0.4;
            }
        }

        /* SCROLL REVEAL */
        .scroll-reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .scroll-reveal.revealed {
            opacity: 1;
            transform: translateY(0);
        }

        /* SOBRE */
        #sobre {
            background: linear-gradient(to bottom, var(--cream) 0%, #F0F8F0 100%);
        }

        .sobre-container {
            display: grid;
            grid-template-columns: 1fr 1.3fr;
            gap: 5rem;
            align-items: center;
        }

        .sobre-image-wrapper {
            position: relative;
        }

        .sobre-image-wrapper::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 20px;
            right: -20px;
            bottom: -20px;
            background: linear-gradient(135deg, var(--light-brown), var(--soft-green));
            opacity: 0.3;
            border-radius: 24px;
            z-index: -1;
        }

        .sobre-image {
            width: 100%;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
            position: relative;
            z-index: 1;
        }
            width: 100%;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
        }

        .sobre-content h3 {
            font-family: 'Quicksand', sans-serif;
            font-size: 1.8rem;
            color: var(--primary-brown);
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .sobre-content p {
            margin-bottom: 1.5rem;
            color: var(--text-body);
            font-size: 1rem;
            line-height: 1.8;
        }

        .qualifications {
            margin-top: 2rem;
        }

        .qualification-item {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1rem;
            padding: 1.2rem;
            background: white;
            border-radius: 16px;
            border-left: 4px solid var(--soft-green);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .qualification-item:hover {
            transform: translateX(8px);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }

                        .qualification-icon {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--soft-green), var(--dark-green));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            flex-shrink: 0;
        }

        .qualification-icon svg {
            width: 24px;
            height: 24px;
            stroke: white;
        }}

        .qualification-text {
            flex: 1;
        }

        .qualification-text strong {
            display: block;
            color: var(--text-dark);
            margin-bottom: 0.3rem;
            font-weight: 600;
        }

        /* SERVIÇOS */
        #servicos {
            background: linear-gradient(135deg, var(--cream) 0%, var(--light-brown) 50%, var(--cream) 100%);
        }

        .servicos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
            margin-top: 3rem;
        }

        .servico-card {
            background: white;
            padding: 2.5rem;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            transition: all 0.4s ease;
            text-align: center;
        }

        .servico-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
        }

                        .servico-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--soft-green), var(--dark-green));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin: 0 auto 1.5rem;
            transition: transform 0.3s ease;
        }

        .servico-icon svg {
            width: 40px;
            height: 40px;
            stroke: white;
        }

        .servico-card:hover .servico-icon {
            transform: scale(1.1);
        }}

        .servico-card h3 {
            font-family: 'Quicksand', sans-serif;
            font-size: 1.5rem;
            color: var(--text-dark);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .servico-card p {
            color: var(--text-body);
            margin-bottom: 1.5rem;
            line-height: 1.7;
        }

        .servico-features {
            list-style: none;
            text-align: left;
            margin-top: 1.5rem;
        }

        .servico-features li {
            padding: 0.6rem 0;
            color: var(--text-body);
            padding-left: 1.8rem;
            position: relative;
            font-size: 0.95rem;
        }

        .servico-features li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--soft-green);
            font-weight: bold;
            font-size: 1.1rem;
        }

        .servico-link {
            display: inline-block;
            margin-top: 1rem;
            color: var(--primary-brown);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.3s ease;
        }

        .servico-link:hover {
            color: var(--soft-green);
        }

        /* DIFERENCIAIS */
        #diferenciais {
            background: linear-gradient(to bottom, #F0F8F0 0%, var(--cream) 100%);
        }

        .diferenciais-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .diferencial-card {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
        }

        .diferencial-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .diferencial-card h3 {
            font-family: 'Quicksand', sans-serif;
            font-size: 1.2rem;
            color: var(--primary-brown);
            margin-bottom: 0.8rem;
            font-weight: 600;
        }

        .diferencial-card p {
            font-size: 0.95rem;
            color: var(--text-body);
            line-height: 1.7;
        }

        /* COMO FUNCIONA */
        #processo {
            background: linear-gradient(135deg, var(--light-brown) 0%, var(--cream) 100%);
        }

        .processo-container {
            max-width: 900px;
            margin: 3rem auto 0;
        }

        .processo-step {
            background: white;
            padding: 2.5rem;
            border-radius: 20px;
            margin-bottom: 2rem;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            border-left: 5px solid var(--soft-green);
            transition: all 0.3s ease;
        }

        .processo-step:hover {
            transform: translateX(10px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
        }

        .processo-step h3 {
            font-family: 'Quicksand', sans-serif;
            color: var(--primary-brown);
            margin-bottom: 1rem;
            font-size: 1.4rem;
            font-weight: 600;
        }

        .processo-step p {
            color: var(--text-body);
            line-height: 1.8;
        }

        /* DEPOIMENTOS */
        #depoimentos {
            background: linear-gradient(to bottom, var(--cream) 0%, #F0F8F0 100%);
        }

        .depoimentos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2.5rem;
            margin-top: 3rem;
        }

        .depoimento-card {
            background: white;
            padding: 2.5rem;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            border-left: 4px solid var(--primary-brown);
            position: relative;
        }

        .depoimento-card::before {
            content: '"';
            position: absolute;
            top: 1rem;
            left: 1.5rem;
            font-size: 4rem;
            color: var(--light-brown);
            font-family: Georgia, serif;
            line-height: 1;
        }

        .depoimento-texto {
            font-style: italic;
            color: var(--text-body);
            margin-bottom: 1.5rem;
            line-height: 1.8;
            position: relative;
            z-index: 1;
        }

        .depoimento-autor {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 0.95rem;
        }

        .depoimentos-badge {
            text-align: center;
            margin-top: 3rem;
            font-size: 1.1rem;
            color: var(--primary-brown);
            font-weight: 600;
        }

        /* FAQ */
        #faq {
            background: linear-gradient(135deg, var(--cream) 0%, var(--light-brown) 100%);
        }

        .faq-container {
            max-width: 900px;
            margin: 3rem auto 0;
        }

        .faq-item {
            background: white;
            margin-bottom: 1.5rem;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 3px 15px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
        }

        .faq-item:hover {
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.1);
        }

        .faq-question {
            padding: 1.8rem 2rem;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            transition: background 0.3s ease;
        }

        .faq-question:hover {
            background: var(--cream);
        }

        .faq-question h3 {
            font-family: 'Quicksand', sans-serif;
            font-size: 1.1rem;
            color: var(--text-dark);
            font-weight: 600;
            text-align: left;
        }

        .faq-icon {
            width: 32px;
